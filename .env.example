# ── JWT (필수 — 서버 시작 전 반드시 설정) ──────────────────
# 생성: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# ── 데이터베이스 ────────────────────────────────────────────
DATABASE_URL=sqlite:///./vm_console.db

# ── CORS (프론트엔드 URL) ───────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
FRONTEND_URL=http://localhost:3000

# ── VM 설정 ─────────────────────────────────────────────────
VM_ROOT_PASSWORD=

# ── SMTP (이메일 인증) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── DataGSM OpenAPI ─────────────────────────────────────────
DATAGSM_API_KEY=

# ── DataGSM OAuth ───────────────────────────────────────────
DATAGSM_CLIENT_ID=
DATAGSM_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/oauth/callback
OAUTH_STORE_MODE=memory
WEB_CONCURRENCY=1

# ── 게이트웨이 (라우터) ─────────────────────────────────────
GATEWAY_PUBLIC_IP=
GATEWAY_IP=
GATEWAY_USER=
GATEWAY_PASSWORD=

# ── 노드 공용 SSH (스니펫 업로드용) ─────────────────────────
NODE_SSH_USER=
NODE_SSH_PASSWORD=

# ── 노드 1 ──────────────────────────────────────────────────
NODE_1_NAME=gsmgpu1
NODE_1_IP=
NODE_1_PORT=8006
NODE_1_USER=root@pam
NODE_1_PASSWORD=
NODE_1_SSH_PORT=10011
NODE_1_BASE_PORT=21000

